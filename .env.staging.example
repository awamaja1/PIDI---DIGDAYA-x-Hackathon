# Staging Environment Configuration Template
# Copy this file to .env.staging and fill in the values

NODE_ENV=staging
LOG_LEVEL=info

# Backend API
BACKEND_API_PORT=3000
BACKEND_API_URL=http://backend-api-staging:3000

# Besu Configuration
BESU_RPC_URL=http://besu-staging:8545
BESU_WS_URL=ws://besu-staging:8546
BESU_CHAIN_ID=1337
BESU_CONSENSUS_MECHANISM=qbft

# CORS & Security
CORS_ORIGIN=https://staging.garuda-link.local
API_KEY_STAGING=your-staging-api-key-here
JWT_SECRET=your-jwt-secret-here

# Database (if needed for audit storage)
DB_HOST=postgres-staging
DB_PORT=5432
DB_NAME=garuda_link_staging
DB_USER=garuda_user
DB_PASSWORD=change-this-password
DB_SSL=true

# AI Engine
AI_ENGINE_URL=http://ai-engine-staging:8000
AI_ENGINE_PORT=8000

# Governance
GOVERNANCE_EVIDENCE_TTL_HOURS=24
GOVERNANCE_SUMMARY_RETENTION_DAYS=90

# Monitoring & Observability
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
DATADOG_API_KEY=your-datadog-api-key
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
