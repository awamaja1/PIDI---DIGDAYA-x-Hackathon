{
  "name": "garuda-link-backend-api",
  "version": "0.2.0",
  "private": true,
  "description": "PoC API Gateway GARUDA-LINK",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "verify:mock": "powershell -ExecutionPolicy Bypass -File scripts/verify-mock-local.ps1",
    "test:contract": "node --test --test-concurrency=1 tests/contract/*.test.js",
    "test:integration": "node --test --test-concurrency=1 tests/integration/*.test.js",
    "test:bench:governance": "node tests/governance-benchmarks.js"
  },
  "dependencies": {
    "dotenv": "16.6.1",
    "ethers": "6.16.0",
    "express": "4.22.1"
  }
}
